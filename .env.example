# Clockify API Configuration

# Your Clockify API key
# Get it from: https://app.clockify.me/user/settings (scroll to API section)
CLOCKIFY_API_KEY=your_api_key_here

# Your Clockify Workspace ID
# Find it in Clockify workspace settings or in the URL when viewing your workspace
# Format: 64-character hexadecimal string
CLOCKIFY_WORKSPACE_ID=your_workspace_id_here

# Optional: Override the default API URL (usually not needed)
# CLOCKIFY_API_URL=https://api.clockify.me/api/v1
